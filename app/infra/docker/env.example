# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/social_media

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Redis Configuration
REDIS_URL=redis://localhost:6379

# MinIO/S3 Configuration
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=social-media-files
MINIO_REGION=us-east-1

# Service Ports
AUTH_SVC_PORT=3001
USERS_SVC_PORT=3002
POSTS_SVC_PORT=3003
MEDIA_SVC_PORT=3004
FEED_SVC_PORT=3005
WEB_PORT=3000

# Environment
NODE_ENV=development

# API URLs (for service-to-service communication)
AUTH_SVC_URL=http://localhost:3001
USERS_SVC_URL=http://localhost:3002
POSTS_SVC_URL=http://localhost:3003
MEDIA_SVC_URL=http://localhost:3004
FEED_SVC_URL=http://localhost:3005

# Frontend Environment Variables
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_AUTH_SVC_URL=http://localhost:3001
NEXT_PUBLIC_USERS_SVC_URL=http://localhost:3002
NEXT_PUBLIC_POSTS_SVC_URL=http://localhost:3003
NEXT_PUBLIC_MEDIA_SVC_URL=http://localhost:3004
NEXT_PUBLIC_FEED_SVC_URL=http://localhost:3005
